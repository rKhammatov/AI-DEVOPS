# Скопируй в .env и заполни реальными значениями.
# .env не коммитится в git (см. .gitignore).

# Креды и имя БД. Их читает официальный образ postgres ТОЛЬКО при первой
# инициализации тома (когда pg_data пуст). Если том уже создан, смена пароля
# здесь НЕ изменит пароль в БД — нужен `ALTER ROLE ... PASSWORD ...`
# или пересоздание тома (`down -v`, что сотрёт данные).
POSTGRES_USER=appuser
POSTGRES_PASSWORD=замени_на_надёжный_пароль
POSTGRES_DB=appdb
